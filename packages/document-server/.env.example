# MCP Document Server — Environment Variables
# Copy to .env and fill in values

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8100
LOG_LEVEL=info

# ── Security ─────────────────────────────────────────────────────────────────
# Optional: require this Bearer token on all /invoke requests
# Leave blank to disable authentication (OK for internal / Docker-only deployment)
API_KEY=

# Maximum file size in megabytes (base64-decoded)
MAX_FILE_SIZE_MB=50

# ── PDF defaults ─────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=A4   # A4 | LETTER
DEFAULT_FONT=Helvetica
DEFAULT_FONT_SIZE=11

# ── Temp directory ────────────────────────────────────────────────────────────
# Files are written here transiently and deleted immediately after processing
TEMP_DIR=/tmp/mcp-docs

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser clients
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
